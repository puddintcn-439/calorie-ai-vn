{
  "name": "calorie-ai-vn",
  "private": true,
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend": "turbo dev --filter=backend",
    "mobile": "turbo dev --filter=mobile",
    "preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/preflight-check.ps1",
    "health": "powershell -ExecutionPolicy Bypass -File ./scripts/health-check.ps1",
    "monitor:metrics": "node ./scripts/check-production-metrics.js",
    "dev:ports:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-dev-ports.ps1",
    "dev:backend:ready": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend-dev.ps1",
    "dev:mobile:web:ready": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mobile-web.ps1",
    "migrate": "node ./scripts/apply-migration.js"
  },
  "devDependencies": {
    "pg": "^8.20.0",
    "prettier": "^3.3.2",
    "turbo": "^2.9.15",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@expo/config-plugins": {
      "@expo/plist": "0.7.0"
    },
    "@expo/metro-config": {
      "postcss": "8.5.10"
    },
    "@expo/plist": {
      ".": "0.7.0",
      "@xmldom/xmldom": "0.9.10"
    },
    "@xmldom/xmldom": "0.9.10",
    "uuid": "11.1.1",
    "ajv": "8.20.0",
    "postcss": "8.5.10",
    "protobufjs": "7.5.9",
    "qs": "6.15.2",
    "webpack": "5.107.2",
    "@nestjs/common": "$@nestjs/common",
    "@nestjs/core": "$@nestjs/core",
    "lodash": "4.18.1",
    "node-emoji": {
      "lodash": "4.18.1"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "@sentry/node": "^8.12.0",
    "prom-client": "^14.0.0"
  }
}
