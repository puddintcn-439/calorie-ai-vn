# ===========================
# BACKEND (NestJS)
# ===========================
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

GEMINI_API_KEY_PRIMARY=your_gemini_api_key_primary_here
# Optional backup key (used automatically when primary is rate/quota-limited or invalid)
GEMINI_API_KEY_BACKUP=your_gemini_api_key_backup_here
# Backwards-compat: legacy `GEMINI_API_KEY` will be treated as the primary key if present
GEMINI_API_KEY=your_gemini_api_key_here
AI_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-2.5-flash-lite
AI_MAX_OUTPUT_TOKENS=2048
AI_PROVIDER_TIMEOUT_MS=15000
AI_IMAGE_PROVIDER_TIMEOUT_MS=25000
AI_PROVIDER_RETRIES=0
AI_PROVIDER_MAX_CONCURRENCY=3
GOOGLE_SEARCH_ENABLED=true
GOOGLE_SEARCH_API_KEY=your_google_custom_search_api_key_here
GOOGLE_SEARCH_CX=your_google_custom_search_engine_id_here
TAVILY_SEARCH_ENABLED=true
TAVILY_API_KEY=your_tavily_api_key_here
USDA_API_KEY=DEMO_KEY

JWT_SECRET=change_this_to_a_long_random_string
PORT=3000

# Billing / Stripe test mode
# Use Stripe test-mode keys only for local/staging verification.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret_here
STRIPE_PRICE_PREMIUM_MONTHLY=price_your_premium_monthly_price_id_here
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price_id_here
STRIPE_PRICE_PREMIUM_ANNUAL=price_your_premium_annual_price_id_here
STRIPE_PRICE_PRO_ANNUAL=price_your_pro_annual_price_id_here
BILLING_SUCCESS_URL=http://localhost:3000/billing/success
BILLING_CANCEL_URL=http://localhost:3000/billing/cancel
USD_TO_VND_RATE=26000

# Billing / PayOS prepaid checkout (Vietnam)
# Use placeholders only here. Real values belong in local/hosted env, never source code.
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here
PAYOS_RETURN_URL=http://localhost:3000/billing/return/payos
PAYOS_CANCEL_URL=http://localhost:3000/billing/cancel/payos

# Notifications / email adapter
# EMAIL_PROVIDER=none keeps email delivery disabled while in-app notification persistence still works.
EMAIL_PROVIDER=none
EMAIL_FROM=Calorie AI <support@example.com>
RESEND_API_KEY=your_resend_api_key_here

# ===========================
# MOBILE (Expo)
# ===========================
EXPO_PUBLIC_API_URL=http://localhost:3000
# Optional comma-separated fallback API URLs for mobile LAN testing.
# Example: EXPO_PUBLIC_API_FALLBACK_URLS=http://192.168.0.103:3000,http://192.168.1.5:3000
EXPO_PUBLIC_API_FALLBACK_URLS=
EXPO_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
EXPO_PUBLIC_EAS_PROJECT_ID=your_expo_eas_project_id_here
