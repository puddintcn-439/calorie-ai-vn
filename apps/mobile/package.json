    "axios": "^1.7.2",
    "expo": "^54.0.34",
    "expo-asset": "~12.0.13",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "^55.0.32",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-health-connect": "^0.1.1",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "*",
    "expo-image-picker": "~17.0.11",
