{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client --host lan",
    "dev:web": "expo start --web --port 19006",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export --platform web",
    "build:native": "eas build",
    "e2e:setup": "npx playwright install",
    "e2e": "npx playwright test",
    "e2e:ci": "npx playwright test --reporter=list",
    "build:android:preview": "npm exec eas-cli build -- --platform android --profile preview",
    "build:ios:preview": "npm exec eas-cli build -- --platform ios --profile preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@calorie-ai/types": "file:../../packages/types",
    "@expo/vector-icons": "^15.1.1",
    "@kingstinct/react-native-healthkit": "^14.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.43.0",
    "axios": "^1.7.2",
    "expo": "^56.0.8",
    "expo-asset": "^56.0.15",
    "expo-av": "^16.0.8",
    "expo-camera": "^56.0.7",
    "expo-dev-client": "~56.0.18",
    "expo-file-system": "^56.0.7",
    "expo-font": "^56.0.5",
    "expo-haptics": "^56.0.3",
    "expo-health-connect": "^0.1.1",
    "expo-image": "^56.0.9",
    "expo-image-manipulator": "^56.0.16",
    "expo-image-picker": "^56.0.15",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "^56.0.13",
    "expo-notifications": "^56.0.15",
    "expo-router": "^56.2.8",
    "expo-secure-store": "^56.0.4",
    "expo-status-bar": "^56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-health-connect": "^3.5.0",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "zustand": "4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@playwright/test": "^1.35.0",
    "@types/react": "19.2.16",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@expo/config-plugins": {
      "@expo/plist": "0.7.0"
    },
    "@expo/plist": {
      ".": "0.7.0",
      "@xmldom/xmldom": "0.9.10"
    },
    "@xmldom/xmldom": "0.9.10",
    "postcss": "8.5.10",
    "qs": "6.15.2",
    "webpack": "5.107.2"
  }
