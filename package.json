{
  "name": "calorie-ai-vn",
  "private": true,
  "packageManager": "npm@10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend": "turbo dev --filter=backend",
    "mobile": "turbo dev --filter=mobile",
    "preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/preflight-check.ps1",
    "health": "powershell -ExecutionPolicy Bypass -File ./scripts/health-check.ps1",
    "dev:ports:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-dev-ports.ps1",
    "dev:backend:ready": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend-dev.ps1",
    "dev:mobile:web:ready": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mobile-web.ps1",
    "migrate": "node ./scripts/apply-migration.js"
  },
  "devDependencies": {
    "pg": "^8.20.0",
    "prettier": "^3.3.2",
    "turbo": "^2.3.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@expo/config-plugins": {
      "@expo/plist": "0.7.0"
    },
    "@expo/plist": {
      ".": "0.7.0",
      "@xmldom/xmldom": "0.9.10"
    },
    "@xmldom/xmldom": "0.9.10",
    "@nestjs/common": "$@nestjs/common",
    "@nestjs/core": "$@nestjs/core",
    "lodash": "4.18.1",
    "node-emoji": {
      "lodash": "4.18.1"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@sentry/node": "^8.12.0",
    "expo-linking": "^8.0.12",
    "prom-client": "^14.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-worklets": "^0.8.3",
    "react-native-worklets-core": "^1.6.3"
  }
}
