# Example env for apps/mobile
# Copy to .env locally and fill in values. Do NOT commit .env with secrets.

# Backend API
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_EAS_PROJECT_ID=your_eas_project_id_here

# Supabase (use anon key for client-side; do not store service_role)
EXPO_PUBLIC_SUPABASE_URL=https://[your-ref].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
